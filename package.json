{
  "name": "wsgate-monorepo",
  "private": true,
  "scripts": {
    "build": "pnpm -r build",
    "dev:ui": "pnpm --filter @wsgate/ui dev",
    "dev:example": "pnpm --filter nest-example dev",
    "lint": "pnpm exec biome lint packages/",
    "format": "pnpm exec biome format packages/ --write",
    "check": "pnpm exec biome check --write packages/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "semantic-release": "^25.0.3"
  }
}
